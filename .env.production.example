# Production Environment Variables Template
# Copy this file and configure in Render Dashboard

NODE_ENV=production
PORT=3000

# MongoDB Configuration
MONGODB_URI=your_production_mongodb_uri
MONGODB_NAME=db_medifollow

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_key_change_this
JWT_EXPIRES_IN=24h

# Email Configuration
EMAIL_HOST=smtp.gmail.com
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_specific_password

# Frontend URL
FRONTEND_URL=https://medifollow.vercel.app

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# AI API Keys
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key

# Twilio Configuration
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Public Base URL (Your Render backend URL)
PUBLIC_BASE_URL=https://your-backend-app.onrender.com

# ML Services
GRAVITY_SERVICE_URL=https://gravity-service.onrender.com
ML_SERVICE_URL=https://ml-service-vkpy.onrender.com
